# Default: auto-detect text vs binary.
# Text files are stored with LF in the repo and checked out with LF.
* text=auto eol=lf

# Shell scripts must stay LF (executed on Linux).
*.sh text eol=lf

# Explicit source/text types -> LF.
*.h    text eol=lf
*.hpp  text eol=lf
*.ipp  text eol=lf
*.c    text eol=lf
*.cc   text eol=lf
*.cpp  text eol=lf
*.cmake text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.xml  text eol=lf
*.rviz text eol=lf
*.launch text eol=lf
*.in   text eol=lf

# Known-binary types: never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.so   binary
*.a    binary
*.lib  binary
*.dll  binary
*.bin  binary

# Vendored third-party code: keep exactly as imported (do not renormalize).
# Keep this block LAST so it overrides the rules above for these paths.
soslab_api/thirdparty/** -text
